# ── Server ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Auth ─────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production

# First user to register with this email gets admin role automatically
ADMIN_EMAIL=admin@example.com

# ── MongoDB ───────────────────────────────────────────────────────
# Free cluster at https://cloud.mongodb.com
# Leave blank to use local MongoDB
MONGO_URI=mongodb://localhost:27017/fitverse

# ── AWS S3 (optional — local disk used if not set) ────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
S3_BUCKET=fitverse-uploads

# ── Replicate AI Try-On (optional — shows original photo if not set)
# Get token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_token_here
